# Boredom & Dungeons — Unity .gitignore
# Keep real project files in Git:
# - Assets/** including .meta files
# - ProjectSettings/**
# - Packages/**
# - User-authored scripts, prefabs, materials, scenes and curated design docs
#
# Do NOT ignore *.meta globally. Unity .meta files are required.

# -----------------------------------------------------------------------------
# Unity generated folders — never commit
# -----------------------------------------------------------------------------
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/
/[Cc]ache/

# Unity cache / generated files
*.pidb
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta
*.pdb.meta
*.mdb.meta
sysinfo.txt

# Unity crash / diagnostics
CrashReports/
crashlytics-build.properties

# Unity generated/temporary Android and Addressables data
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# Optional Unity Asset Store tools/plugin caches
/[Aa]ssets/AssetStoreTools*
/[Aa]ssets/Plugins/Editor/JetBrains*

# -----------------------------------------------------------------------------
# IDE / editor generated files
# -----------------------------------------------------------------------------
.vs/
.vscode/
.idea/
.consulo/
.gradle/
ExportedObj/

*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.booproj
*.svd
*.DotSettings.user

# Rider / ReSharper
_ReSharper*/
*.resharper
*.sln.DotSettings.user

# Visual Studio / MonoDevelop
*.pidb
*.userprefs

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Local archives, exported packages and builds
# -----------------------------------------------------------------------------
*.zip
*.rar
*.7z
*.tar
*.tar.gz
*.unitypackage
*.apk
*.aab
*.app
*.ipa
*.xcarchive
*.dSYM

# -----------------------------------------------------------------------------
# Local logs, temp, backups and QA exports
# -----------------------------------------------------------------------------
*.log
*.bak
*.backup
*.orig
*.swp
*.swo
*.tmp
*.temp
/ONE_CLICK_QA*.txt
/STABILITY_*.txt
/PLAY_MODE_*.txt
/QA_REPORT*.txt

# -----------------------------------------------------------------------------
# Python / tooling caches
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# Node tooling if added later
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/

# -----------------------------------------------------------------------------
# Local environment files
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Large local video/audio exports generated during tests
# Keep intentional source assets under Assets/_Project.
# -----------------------------------------------------------------------------
*.mp4
*.mov
*.avi
*.mkv
*.wav.tmp
*.mp3.tmp

# -----------------------------------------------------------------------------
# One-shot delivery packages and patch helpers
# -----------------------------------------------------------------------------
/.package_tools/
/PACKAGE_*.txt
/PACKAGE_*.json
/PACKAGE_MANIFEST*
/README_C01_*.txt
/_PACKAGE_*.txt
/APPLY_*.command
/RUN_*_FIX*.command
/RUN_STABILITY_SOURCE_SCAN.command
/README_HE.txt
/tools/apply_*.py

# -----------------------------------------------------------------------------
# Duplicate/versioned status snapshots
# Keep only PROJECT_STATUS.md as the authoritative live tracker.
# -----------------------------------------------------------------------------
/PROJECT_STATUS_CURRENT*.md
/WORKING_NOW.md

# -----------------------------------------------------------------------------
# Generated version/package docs from iterative builds
# -----------------------------------------------------------------------------
README_V*.md
README_CLEAN_CORE*.md
README_*_FIX*.md
README_*_HOTFIX*.md
README_*_PATCH*.md
README_*_V[0-9]*.md
README_*_V[0-9]*_*.md
*_CLEAN_CORE*.md
*_clean_core*.md
package_manifest.json
*_manifest.json

# Generated extracted version package folders
boredom_and_dungeons_clean_core*/
clean_core*/
bd_v*/
bd_*_upload*/
releases/

# Authoritative progress tracker hygiene
/PROJECT_STATUS_CURRENT_V*.md
.ai/

# -----------------------------------------------------------------------------
# Local rich-text duplicate of the canonical Codex operating contract
# -----------------------------------------------------------------------------
/AGENTS.rtf
