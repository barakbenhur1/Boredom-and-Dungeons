# Boredom & Dungeons — Unity .gitignore
# Keep real project files in Git:
# - Assets/** including .meta files
# - ProjectSettings/**
# - Packages/**
# - User-authored scripts, prefabs, materials, scenes and design docs
#
# Do NOT ignore *.meta globally. Unity .meta files are required.

# -----------------------------------------------------------------------------
# Unity generated folders — never commit
# -----------------------------------------------------------------------------
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/
/[Cc]ache/

# Unity cache / generated files
*.pidb
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta
*.pdb.meta
*.mdb.meta
sysinfo.txt

# Unity crash / diagnostics
CrashReports/
crashlytics-build.properties

# Unity generated/temporary Android and Addressables data
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# Optional Unity Asset Store tools/plugin caches
/[Aa]ssets/AssetStoreTools*
/[Aa]ssets/Plugins/Editor/JetBrains*

# -----------------------------------------------------------------------------
# IDE / editor generated files
# -----------------------------------------------------------------------------
.vs/
.vscode/
.idea/
.consulo/
.gradle/
ExportedObj/

*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.booproj
*.svd
*.DotSettings.user

# Rider / ReSharper
_ReSharper*/
*.resharper
*.sln.DotSettings.user

# Visual Studio / MonoDevelop
*.pidb
*.userprefs

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Local archives, exported packages and builds
# -----------------------------------------------------------------------------
*.zip
*.rar
*.7z
*.tar
*.tar.gz
*.unitypackage
*.apk
*.aab
*.app
*.ipa
*.xcarchive
*.dSYM

# -----------------------------------------------------------------------------
# Local logs, temp, backups
# -----------------------------------------------------------------------------
*.log
*.bak
*.backup
*.orig
*.swp
*.swo
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Python / tooling caches sometimes created by helper scripts
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# Node tooling if added later
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/

# -----------------------------------------------------------------------------
# Local environment files
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Large local video/audio exports generated during tests
# Keep source assets intentionally added under Assets/_Project/Audio if needed.
# -----------------------------------------------------------------------------
*.mp4
*.mov
*.avi
*.mkv
*.wav.tmp
*.mp3.tmp
