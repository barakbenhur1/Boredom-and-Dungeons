+        private void ResolveFirstLaunchTutorialProductionMelee(float damage, bool heavy)
+        {
+            TutorialEnemyActor actor = FindClosestLivingTutorialActor(heavy ? 210f : 165f);
+            if (actor == null)
+            {
+                ShowFirstLaunchTutorialSuccess("NO TARGET IN RANGE");
